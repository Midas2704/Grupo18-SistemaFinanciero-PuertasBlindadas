        <mxCell id="3xeFfSdvASba5G_G9Aon-40" parent="3xeFfSdvASba5G_G9Aon-37" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=1;fontSize=10;align=left;verticalAlign=top;spacing=8;fontStyle=0" value="FUENTES DE DATOS:&lt;br&gt;  - mindicador.cl (UF, Dólar, UTM, IVP, IPC)&lt;br&gt;  - Banco Central de Chile (API opcional)&lt;br&gt;  - Salida a internet desde servidor de aplicaciones&lt;br&gt;  - Puerto 443 habilitado (HTTPS)&lt;br&gt;  - Timeout: 10 segundos&lt;br&gt;  - REST / JSON sobre HTTPS&lt;br&gt;  - No requiere autenticación para APIs públicas&lt;br&gt;  - 3 reintentos con backoff exponencial (1s, 2s, 4s)&lt;br&gt;  - Cache local de 2 horas en servidor de aplicaciones&lt;br&gt;  - Fallback: valores del día anterior si API no responde" vertex="1">
          <mxGeometry height="244" width="380" y="76" as="geometry" />
        </mxCell>
        <mxCell id="3xeFfSdvASba5G_G9Aon-41" parent="3xeFfSdvASba5G_G9Aon-37" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=1;fontStyle=2;fontSize=12;align=left;verticalAlign=middle;spacingLeft=10;" value="&amp;lt;&amp;lt;Hardware y Software&amp;gt;&amp;gt;" vertex="1">
